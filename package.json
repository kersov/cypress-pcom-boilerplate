{
  "name": "cypress-pcom-boilerplate",
  "version": "0.0.3",
  "description": "A foundational Cypress boilerplate project utilizing the Page Component Object Model (PCOM) for scalable, maintainable end-to-end testing. Supports cross-environment, cross-device, multi-language testing, and test tagging.",
  "keywords": [
    "cypress",
    "PCOM",
    "e2e"
  ],
  "homepage": "https://github.com/kersov/cypress-pcom-boilerplate#readme",
  "bugs": {
    "url": "https://github.com/kersov/cypress-pcom-boilerplate/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kersov/cypress-pcom-boilerplate.git"
  },
  "license": "MIT",
  "author": "Oleksii Kersov",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "test:e2e": "npm run test:e2e:dev:testapp",
    "test:e2e:dev:testapp": "npm run test:e2e:dev:testapp:default",
    "test:e2e:dev:testapp:default": "npm-run-all test:e2e:dev:testapp:default:*",
    "test:e2e:dev:testapp:default:mobile": "npx cypress run --env site=testapp,env=dev,locale=default,mode=mobile,grepTags=@self",
    "test:e2e:dev:testapp:default:tablet": "npx cypress run --env site=testapp,env=dev,locale=default,mode=tablet,grepTags=@self",
    "test:e2e:dev:testapp:default:desktop": "npx cypress run --env site=testapp,env=dev,locale=default,mode=desktop,grepTags=@self",
    "test:e2e:stg:testapp": "npm run test:e2e:stg:testapp:default",
    "test:e2e:stg:testapp:default": "npm-run-all test:e2e:stg:testapp:default:*",
    "test:e2e:stg:testapp:default:mobile": "npx cypress run --env site=testapp,env=stg,locale=default,mode=mobile,grepTags=@self",
    "test:e2e:stg:testapp:default:tablet": "npx cypress run --env site=testapp,env=stg,locale=default,mode=tablet,grepTags=@self",
    "test:e2e:stg:testapp:default:desktop": "npx cypress run --env site=testapp,env=stg,locale=default,mode=desktop,grepTags=@self",
    "test:e2e:prod:testapp": "npm run test:e2e:prod:testapp:default",
    "test:e2e:prod:testapp:default": "npm-run-all test:e2e:prod:testapp:default:*",
    "test:e2e:prod:testapp:default:mobile": "npx cypress run --env site=testapp,env=prod,locale=default,mode=mobile,grepTags=@self",
    "test:e2e:prod:testapp:default:tablet": "npx cypress run --env site=testapp,env=prod,locale=default,mode=tablet,grepTags=@self",
    "test:e2e:prod:testapp:default:desktop": "npx cypress run --env site=testapp,env=prod,locale=default,mode=desktop,grepTags=@self",
    "test:e2e:all": "npm-run-all test:e2e:dev:testapp test:e2e:stg:testapp test:e2e:prod:testapp",
    "start-and-test": "npm-run-all --parallel --race app test:e2e:all",
    "app": "npm-run-all --parallel app:*",
    "app:dev": "node test-app/server.js dev",
    "app:stg": "node test-app/server.js stg",
    "app:prod": "node test-app/server.js prod"
  },
  "dependencies": {
    "@cypress/grep": "^4.1.0",
    "cypress": "^14.5.0",
    "cypress-wait-until": "^3.0.2",
    "npm-run-all": "^4.1.5"
  }
}
